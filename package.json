{
  "name": "remote-connection-manager",
  "displayName": "Remote Connection Manager",
  "description": "VS Code extension for managing SSH, SFTP, and FTP connections with a webview file manager.",
  "version": "1.0.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:ftpext.remoteManagerView",
    "onCommand:ftpext.refreshConnections",
    "onCommand:ftpext.openPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ftpext.refreshConnections",
        "title": "Remote Connections: Refresh"
      },
      {
        "command": "ftpext.openPanel",
        "title": "Remote Connections: Open Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ftpext",
          "title": "Remote",
          "icon": "resources/activity-icon.svg"
        }
      ]
    },
    "views": {
      "ftpext": [
        {
          "id": "ftpext.remoteManagerView",
          "name": "Remote File Manager",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ftpext.refreshConnections",
          "when": "view == ftpext.remoteManagerView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  }
}
